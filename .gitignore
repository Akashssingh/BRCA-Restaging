# ── Large data directories (not tracked) ─────────────────────────────────────
# Download locally using the GDC client — see README for instructions
gdc_downloads/

# Raw GDC cart exports (clinical TSVs are in gdc_accessory_files/ instead)
Gaivi_package/

# Stage-organized symlink tree (generated from gdc_downloads — regenerate locally)
stage_organized/

# ── OCR extraction outputs (large / generated) ────────────────────────────────
# Per-case JSON and TXT are regenerated by running brca_ocr_extract.py
ocr_output/json/
ocr_output/txt/
ocr_output/features/
# Keep brca_features_master.csv — it's the expensive artifact worth tracking
!ocr_output/brca_features_master.csv

